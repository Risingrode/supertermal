# Web 登录密码。留空则首次启动自动生成并回写到当前文件
SUPERTERMAL_PASSWORD=

# 是否要求首次登录后立即修改密码
SUPERTERMAL_PASSWORD_MUST_CHANGE=false

# 服务监听端口（默认 8002）
PORT=8002

# Claude CLI 路径（默认在 PATH 中查找 claude）
CLAUDE_PATH=claude

# Codex CLI 路径（默认在 PATH 中查找 codex）
CODEX_PATH=codex

# PushPlus Token（可选，首次启动会自动迁移到 config/notify.json）
PUSHPLUS_TOKEN=
